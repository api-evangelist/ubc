{
  "$schema": "https://json-structure.org/meta/core/v0",
  "$id": "https://raw.githubusercontent.com/api-evangelist/ubc/main/json-structure/ubc-dataverse-structure.json",
  "name": "UBCAbacusDataverse",
  "description": "JSON Structure description of a Dataverse collection in UBC Library's Abacus repository.",
  "type": "object",
  "properties": {
    "id": { "type": "int64", "description": "Internal numeric database id." },
    "name": { "type": "string", "description": "Display name of the dataverse." },
    "alias": { "type": "string", "description": "URL-safe alias." },
    "description": { "type": "string" },
    "affiliation": { "type": "string" },
    "dataverseType": { "type": "string" },
    "permissionRoot": { "type": "boolean" },
    "metadataBlockRoot": { "type": "boolean" }
  },
  "required": ["id", "alias"]
}
